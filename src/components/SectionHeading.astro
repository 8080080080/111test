---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  linkLabel?: string;
  linkHref?: string;
  stackLink?: boolean;
  /** Use h1 for page-level titles (one per page for SEO). */
  titleTag?: "h1" | "h2";
}

const {
  eyebrow,
  title,
  description,
  align = "left",
  linkLabel,
  linkHref,
  stackLink = false,
  titleTag = "h2"
} = Astro.props;

const titleClass = `text-panel inline-block ${align === "center" ? "max-w-4xl" : "max-w-3xl"} text-3xl sm:text-4xl lg:text-5xl`;

const alignment =
  align === "center"
    ? "mx-auto max-w-5xl text-center items-center"
    : "max-w-3xl text-left items-start";
---

<div class={`flex flex-col gap-4 ${alignment}`}>
  {eyebrow && <p class="eyebrow text-panel-compact inline-flex w-fit">{eyebrow}</p>}
  <div class={`flex w-full flex-col gap-4 ${stackLink ? "items-center" : "md:flex-row md:items-end md:justify-between"}`}>
    <div class="space-y-4">
      {titleTag === "h1" ? <h1 class={titleClass}>{title}</h1> : <h2 class={titleClass}>{title}</h2>}
      {description && <p class="text-panel max-w-2xl text-base sm:text-lg">{description}</p>}
    </div>
    {linkLabel && linkHref && (
      <a class={`button-secondary shrink-0 ${stackLink ? "mx-auto" : ""}`} href={linkHref}>
        {linkLabel}
      </a>
    )}
  </div>
</div>
