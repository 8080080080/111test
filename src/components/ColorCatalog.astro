---
import { getWebpVariantUrl } from "../lib/imageRegistry";
import type { Locale } from "../lib/content";
import type { ProductImage } from "../types/content";

interface Props {
  items: ProductImage[];
  id: string;
  mobileFullscreen?: boolean;
  locale?: Locale;
}

const { items, id, mobileFullscreen = false, locale = "ka" } = Astro.props;
const tileSize = 120;
const tileMargin = 5;
const previewSize = 240;
const tileSizesAttr = `${tileSize}px`;
const previewSizesAttr = `${previewSize}px`;
const srcSetFor = (item: ProductImage) => `${item.src} ${item.width}w`;
const firstItem = items[0];
const firstWebp = firstItem ? getWebpVariantUrl(firstItem.src) : "";
const labels = locale === "en" ? {
  viewer: "Full-screen color view",
  closeViewer: "Close full-screen color view",
  close: "Close",
  previous: "Previous color",
  next: "Next color"
} : {
  viewer: "ფერის სრული ეკრანის ხედი",
  closeViewer: "დახურე ფერის სრული ეკრანის ხედი",
  close: "დახურვა",
  previous: "წინა ფერი",
  next: "შემდეგი ფერი"
};
---

<div
  class="color-catalog"
  id={id}
  data-color-catalog
  data-mobile-fullscreen={mobileFullscreen ? "true" : "false"}
  style={`--catalog-tile-size:${tileSize}px; --catalog-tile-margin:${tileMargin}px; --catalog-preview-size:${previewSize}px;`}
>
  <div class="color-catalog__layout" data-catalog-layout>
    {items.map((item, index) => {
      const webp = getWebpVariantUrl(item.src);
      return (
      <button
        type="button"
        class="color-catalog__tile"
        data-catalog-tile
        data-index={index}
        data-src={item.src}
        data-srcset={srcSetFor(item)}
        data-webp-srcset={webp ? `${webp} ${item.width}w` : undefined}
        data-alt={item.alt}
        data-width={item.width}
        data-height={item.height}
        aria-label={item.alt}
      >
        <picture>
          {webp && <source srcset={`${webp} ${item.width}w`} type="image/webp" sizes={tileSizesAttr} />}
          <img
            src={item.src}
            srcset={srcSetFor(item)}
            sizes={tileSizesAttr}
            alt={item.alt}
            width={tileSize}
            height={tileSize}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover"
          />
        </picture>
      </button>
    );
    })}

    <div class="color-catalog__preview" data-catalog-preview aria-hidden="true">
      {firstItem && (
        <picture>
          <source data-catalog-preview-source srcset={firstWebp ? `${firstWebp} ${firstItem.width}w` : undefined} type="image/webp" sizes={previewSizesAttr} />
          <img
            data-catalog-preview-image
            src={firstItem.src}
            srcset={srcSetFor(firstItem)}
            sizes={previewSizesAttr}
            alt={firstItem.alt}
            width={previewSize}
            height={previewSize}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover"
          />
        </picture>
      )}
    </div>
  </div>

  {mobileFullscreen && (
    <dialog class="color-catalog__viewer" data-catalog-viewer aria-label={labels.viewer}>
      <div class="color-catalog__viewer-shell">
        <div class="color-catalog__viewer-header">
          <p class="color-catalog__viewer-count" data-catalog-viewer-count>{`1 / ${items.length}`}</p>
          <button type="button" class="color-catalog__viewer-close" data-catalog-viewer-close aria-label={labels.closeViewer}>
            {labels.close}
          </button>
        </div>

        <div class="color-catalog__viewer-stage">
          {items.length > 1 && (
            <>
              <button
                type="button"
                class="color-catalog__viewer-nav color-catalog__viewer-nav--prev"
                data-catalog-viewer-prev
                aria-label={labels.previous}
              >
                <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 18l-6-6 6-6"></path>
                </svg>
              </button>
              <button
                type="button"
                class="color-catalog__viewer-nav color-catalog__viewer-nav--next"
                data-catalog-viewer-next
                aria-label={labels.next}
              >
                <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 18l6-6-6-6"></path>
                </svg>
              </button>
            </>
          )}

          <div class="color-catalog__viewer-track" data-catalog-viewer-track tabindex="0">
            {firstItem && (
              <figure class="color-catalog__viewer-slide" data-catalog-viewer-slide data-index="0">
                <div class="color-catalog__viewer-zoom-frame" data-catalog-viewer-zoom-frame data-index="0">
                  <picture>
                    <source data-catalog-viewer-source srcset={firstWebp ? `${firstWebp} ${firstItem.width}w` : undefined} type="image/webp" sizes="100vw" />
                    <img
                      src={firstItem.src}
                      srcset={srcSetFor(firstItem)}
                      sizes="100vw"
                      alt={firstItem.alt}
                      width={firstItem.width}
                      height={firstItem.height}
                      loading="lazy"
                      decoding="async"
                      class="color-catalog__viewer-image"
                      data-catalog-viewer-image
                    />
                  </picture>
                </div>
              </figure>
            )}
          </div>
        </div>

        <p class="color-catalog__viewer-caption" data-catalog-viewer-caption>{items[0]?.alt ?? ""}</p>
      </div>
    </dialog>
  )}
</div>

<style>
  .color-catalog {
    position: relative;
  }

  .color-catalog__layout {
    position: relative;
    min-height: var(--catalog-tile-size);
  }

  .color-catalog__tile {
    position: absolute;
    width: var(--catalog-tile-size);
    height: var(--catalog-tile-size);
    margin: var(--catalog-tile-margin);
    overflow: hidden;
    border-radius: 1.5rem;
    border: 1px solid rgba(26, 25, 23, 0.08);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 18px 35px rgba(26, 25, 23, 0.08);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .color-catalog__tile {
      transition: none;
    }
  }

  .color-catalog__tile:hover,
  .color-catalog__tile:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(47, 36, 130, 0.26);
    box-shadow: 0 24px 42px rgba(26, 25, 23, 0.14);
  }

  .color-catalog__tile :global(img),
  .color-catalog__preview :global(img) {
    display: block;
  }

  .color-catalog__preview {
    display: none;
  }

  .color-catalog__preview :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .color-catalog__viewer {
    width: 100vw;
    max-width: none;
    min-width: 100vw;
    height: 100dvh;
    min-height: 100dvh;
    margin: 0;
    border: 0;
    padding: 0;
    background: rgba(18, 16, 14, 0.98);
    color: #fff;
  }

  .color-catalog__viewer::backdrop {
    background: rgba(18, 16, 14, 0.8);
  }

  .color-catalog__viewer-shell {
    display: grid;
    min-height: 100dvh;
    grid-template-rows: auto minmax(0, 1fr) auto;
    gap: 1rem;
    padding: max(1rem, env(safe-area-inset-top, 0px)) 1rem max(1rem, env(safe-area-inset-bottom, 0px));
  }

  .color-catalog__viewer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .color-catalog__viewer-count {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.82);
  }

  .color-catalog__viewer-close {
    min-width: 44px;
    min-height: 44px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.1);
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #fff;
    transition: background 180ms ease, border-color 180ms ease, transform 180ms ease;
  }

  .color-catalog__viewer-stage {
    position: relative;
    min-height: 0;
  }

  .color-catalog__viewer-track {
    display: flex;
    height: 100%;
    min-height: 0;
    overflow: hidden;
    overscroll-behavior-x: contain;
    touch-action: pan-x pinch-zoom;
  }

  .color-catalog__viewer-track.is-zoomed {
    touch-action: none;
  }

  .color-catalog__viewer-slide {
    display: flex;
    min-width: 100%;
    flex: 0 0 100%;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 0.5rem 0;
  }

  .color-catalog__viewer-zoom-frame {
    display: flex;
    width: 100%;
    min-height: min(72dvh, 38rem);
    align-items: center;
    justify-content: center;
    overflow: hidden;
    touch-action: pan-x;
  }

  .color-catalog__viewer-zoom-frame.is-zoomed {
    touch-action: none;
  }

  .color-catalog__viewer-zoom-frame.is-dragging {
    cursor: grabbing;
  }

  .color-catalog__viewer-image {
    display: block;
    width: 100%;
    height: auto;
    max-width: 100%;
    max-height: min(72dvh, 38rem);
    object-fit: contain;
    transform-origin: center center;
    will-change: transform;
  }

  .color-catalog__viewer-nav {
    position: absolute;
    top: 50%;
    z-index: 1;
    display: inline-flex;
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.45);
    background: rgba(255, 255, 255, 0.24);
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(10px);
    color: #fff;
    transform: translateY(-50%);
    transition: background 180ms ease, border-color 180ms ease, transform 180ms ease, opacity 180ms ease;
  }

  .color-catalog__viewer-nav:hover,
  .color-catalog__viewer-nav:focus-visible {
    background: rgba(255, 255, 255, 0.34);
    border-color: rgba(255, 255, 255, 0.72);
  }

  .color-catalog__viewer-nav:disabled {
    opacity: 0.35;
  }

  .color-catalog__viewer-nav--prev {
    left: 0.25rem;
  }

  .color-catalog__viewer-nav--next {
    right: 0.25rem;
  }

  .color-catalog__viewer-caption {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.82);
  }

  @media (prefers-reduced-motion: reduce) {
    .color-catalog__viewer-close,
    .color-catalog__viewer-nav {
      transition: none;
    }
  }

  @media (min-width: 768px) {
    .color-catalog__preview {
      position: absolute;
      top: 0;
      left: 0;
      z-index: 30;
      display: block;
      width: var(--catalog-preview-size);
      height: var(--catalog-preview-size);
      overflow: hidden;
      border-radius: 1.75rem;
      border: 1px solid rgba(26, 25, 23, 0.12);
      background: rgba(255, 255, 255, 0.97);
      box-shadow: 0 34px 58px rgba(26, 25, 23, 0.18);
      opacity: 0;
      pointer-events: none;
      transform: translate3d(var(--preview-x, 0px), var(--preview-y, 0px), 0) scale(0.98);
      transform-origin: top left;
      transition: opacity 180ms ease, transform 180ms ease;
    }

    @media (prefers-reduced-motion: reduce) {
      .color-catalog__preview {
        transition: none;
      }
    }

    .color-catalog__preview.is-visible {
      opacity: 1;
      transform: translate3d(var(--preview-x, 0px), var(--preview-y, 0px), 0) scale(1);
    }

    .color-catalog__viewer {
      display: none;
    }
  }
</style>

<script>
  function debounce(fn, delay) {
    let id = 0;
    return (...args) => {
      clearTimeout(id);
      id = window.setTimeout(() => fn(...args), delay);
    };
  }

  const desktopQuery = window.matchMedia("(min-width: 768px)");
  const mobileQuery = window.matchMedia("(max-width: 767px)");

  for (const root of document.querySelectorAll("[data-color-catalog]")) {
    const layout = root.querySelector("[data-catalog-layout]");
    const preview = root.querySelector("[data-catalog-preview]");
    const previewSource = root.querySelector("[data-catalog-preview-source]");
    const previewImage = root.querySelector("[data-catalog-preview-image]");
    const tiles = Array.from(root.querySelectorAll("[data-catalog-tile]"));
    const viewerDialog = root.querySelector("[data-catalog-viewer]");
    const viewerTrack = root.querySelector("[data-catalog-viewer-track]");
    const viewerCount = root.querySelector("[data-catalog-viewer-count]");
    const viewerCaption = root.querySelector("[data-catalog-viewer-caption]");
    const viewerClose = root.querySelector("[data-catalog-viewer-close]");
    const viewerPrev = root.querySelector("[data-catalog-viewer-prev]");
    const viewerNext = root.querySelector("[data-catalog-viewer-next]");
    const viewerSlide = root.querySelector("[data-catalog-viewer-slide]");
    const viewerZoomFrame = root.querySelector("[data-catalog-viewer-zoom-frame]");
    const viewerSource = root.querySelector("[data-catalog-viewer-source]");
    const viewerImage = root.querySelector("[data-catalog-viewer-image]");
    const mobileFullscreenEnabled = root.getAttribute("data-mobile-fullscreen") === "true";

    if (!layout || !preview || tiles.length === 0) {
      continue;
    }

    const rootStyle = getComputedStyle(root);
    const parseCSSVar = (name, fallback) => {
      const value = parseInt(rootStyle.getPropertyValue(name), 10);
      return Number.isNaN(value) ? fallback : value;
    };
    const tileSize = parseCSSVar("--catalog-tile-size", 120);
    const tileMargin = parseCSSVar("--catalog-tile-margin", 5);
    const previewSize = parseCSSVar("--catalog-preview-size", 240);
    const tileStride = tileSize + tileMargin * 2;
    let activeIndex = -1;
    let viewerIndex = 0;
    let lastFocusedTile = null;
    let viewerSwipeStart = null;
    let viewerPointerSwipeStart = null;
    const zoomState = { scale: 1, x: 0, y: 0 };
    const zoomInteraction = {
      pointers: new Map(),
      panPointerId: null,
      panStartX: 0,
      panStartY: 0,
      startX: 0,
      startY: 0,
      pinchDistance: 0,
      pinchScale: 1,
      pinchStartX: 0,
      pinchStartY: 0
    };

    const clamp = (value, min, max) => Math.min(Math.max(value, min), max);
    const isViewerOpen = () => viewerDialog instanceof HTMLDialogElement && viewerDialog.open;

    const getTileData = (index) => {
      const tile = tiles[index];
      if (!(tile instanceof HTMLElement)) {
        return null;
      }

      return {
        src: tile.dataset.src || "",
        srcset: tile.dataset.srcset || tile.dataset.src || "",
        webpSrcset: tile.dataset.webpSrcset || "",
        alt: tile.dataset.alt || "",
        width: Number(tile.dataset.width || tileSize),
        height: Number(tile.dataset.height || tileSize)
      };
    };

    const updatePicture = (source, image, data, sizes, dimensions = null) => {
      if (!data || !(image instanceof HTMLImageElement)) {
        return;
      }

      if (source instanceof HTMLSourceElement) {
        if (data.webpSrcset) {
          source.setAttribute("srcset", data.webpSrcset);
        } else {
          source.removeAttribute("srcset");
        }
        source.setAttribute("sizes", sizes);
      }

      image.src = data.src;
      image.srcset = data.srcset;
      image.sizes = sizes;
      image.alt = data.alt;
      image.width = dimensions?.width ?? data.width;
      image.height = dimensions?.height ?? data.height;
    };

    const setActivePreview = (index) => {
      const data = getTileData(index);
      updatePicture(previewSource, previewImage, data, `${previewSize}px`, { width: previewSize, height: previewSize });
    };

    const setTrackZoomed = (zoomed) => {
      if (viewerTrack instanceof HTMLElement) {
        viewerTrack.classList.toggle("is-zoomed", zoomed);
      }
    };

    const measureImageBase = (referenceScale = zoomState.scale) => {
      if (!(viewerZoomFrame instanceof HTMLElement) || !(viewerImage instanceof HTMLImageElement)) {
        return null;
      }

      const rect = viewerImage.getBoundingClientRect();
      const safeScale = Math.max(referenceScale, 1);

      return {
        frameWidth: Math.max(viewerZoomFrame.clientWidth, 1),
        frameHeight: Math.max(viewerZoomFrame.clientHeight, 1),
        baseWidth: rect.width / safeScale,
        baseHeight: rect.height / safeScale
      };
    };

    const clampZoomOffset = (x, y, nextScale, referenceScale = zoomState.scale) => {
      const measurement = measureImageBase(referenceScale);

      if (!measurement || nextScale <= 1) {
        return { x: 0, y: 0 };
      }

      const maxX = Math.max(0, (measurement.baseWidth * nextScale - measurement.frameWidth) / 2);
      const maxY = Math.max(0, (measurement.baseHeight * nextScale - measurement.frameHeight) / 2);

      return {
        x: clamp(x, -maxX, maxX),
        y: clamp(y, -maxY, maxY)
      };
    };

    const applyZoomState = () => {
      if (!(viewerZoomFrame instanceof HTMLElement) || !(viewerImage instanceof HTMLImageElement)) {
        return;
      }

      viewerImage.style.transform = `translate3d(${zoomState.x}px, ${zoomState.y}px, 0) scale(${zoomState.scale})`;
      viewerZoomFrame.classList.toggle("is-zoomed", zoomState.scale > 1.01);
      setTrackZoomed(zoomState.scale > 1.01);
    };

    const resetZoomState = () => {
      zoomState.scale = 1;
      zoomState.x = 0;
      zoomState.y = 0;

      if (viewerZoomFrame instanceof HTMLElement) {
        viewerZoomFrame.classList.remove("is-dragging");
      }

      zoomInteraction.pointers.clear();
      zoomInteraction.panPointerId = null;
      zoomInteraction.pinchDistance = 0;
      applyZoomState();
    };

    const beginPan = (pointId, point) => {
      zoomInteraction.panPointerId = pointId;
      zoomInteraction.panStartX = point.x;
      zoomInteraction.panStartY = point.y;
      zoomInteraction.startX = zoomState.x;
      zoomInteraction.startY = zoomState.y;
    };

    const getPointerPair = () => {
      const values = Array.from(zoomInteraction.pointers.values());
      return values.length >= 2 ? [values[0], values[1]] : null;
    };

    const renderViewerImage = (index) => {
      const data = getTileData(index);
      updatePicture(viewerSource, viewerImage, data, "100vw");

      if (viewerSlide instanceof HTMLElement) {
        viewerSlide.dataset.index = `${index}`;
      }

      if (viewerZoomFrame instanceof HTMLElement) {
        viewerZoomFrame.dataset.index = `${index}`;
      }
    };

    const setViewerIndex = (index, options = {}) => {
      if (!mobileFullscreenEnabled || tiles.length === 0) {
        return;
      }

      const { focusTrack = false } = options;
      const nextIndex = clamp(index, 0, tiles.length - 1);

      if (nextIndex !== viewerIndex) {
        resetZoomState();
      }

      viewerIndex = nextIndex;
      renderViewerImage(viewerIndex);
      const data = getTileData(viewerIndex);

      if (viewerCount instanceof HTMLElement) {
        viewerCount.textContent = `${viewerIndex + 1} / ${tiles.length}`;
      }

      if (viewerCaption instanceof HTMLElement) {
        viewerCaption.textContent = data?.alt || "";
      }

      if (viewerPrev instanceof HTMLButtonElement) {
        viewerPrev.disabled = viewerIndex === 0;
      }

      if (viewerNext instanceof HTMLButtonElement) {
        viewerNext.disabled = viewerIndex === tiles.length - 1;
      }

      if (focusTrack && viewerTrack instanceof HTMLElement) {
        viewerTrack.focus({ preventScroll: true });
      }
    };

    const stepViewer = (step) => {
      resetZoomState();
      setViewerIndex(viewerIndex + step);
    };

    const closeViewer = () => {
      if (viewerDialog instanceof HTMLDialogElement && viewerDialog.open) {
        viewerDialog.close();
      }
    };

    const openViewer = (index, tile) => {
      if (
        !mobileFullscreenEnabled ||
        !mobileQuery.matches ||
        !(viewerDialog instanceof HTMLDialogElement)
      ) {
        return;
      }

      lastFocusedTile = tile;
      resetZoomState();
      setViewerIndex(index);

      if (!viewerDialog.open) {
        viewerDialog.showModal();
      }

      window.requestAnimationFrame(() => {
        setViewerIndex(index, { focusTrack: true });
      });
    };

    const hidePreview = () => {
      activeIndex = -1;
      preview.classList.remove("is-visible");
      preview.setAttribute("aria-hidden", "true");
    };

    const showPreview = (index) => {
      if (!desktopQuery.matches) {
        hidePreview();
        return;
      }

      const tile = tiles[index];
      if (!tile) {
        return;
      }

      activeIndex = index;
      setActivePreview(index);

      const tileLeft = Number(tile.dataset.left || 0);
      const tileTop = Number(tile.dataset.top || 0);
      const layoutWidth = layout.clientWidth;
      const layoutHeight = Math.max(layout.clientHeight, previewSize);
      const offset = 18;

      let previewX = tileLeft + tileStride + offset;
      if (previewX + previewSize > layoutWidth) {
        previewX = tileLeft - previewSize - offset;
      }
      previewX = clamp(previewX, 0, Math.max(0, layoutWidth - previewSize));

      const centeredTop = tileTop - Math.round((previewSize - tileSize) / 2);
      const previewY = clamp(centeredTop, 0, Math.max(0, layoutHeight - previewSize));

      preview.style.setProperty("--preview-x", `${previewX}px`);
      preview.style.setProperty("--preview-y", `${previewY}px`);
      preview.classList.add("is-visible");
      preview.setAttribute("aria-hidden", "false");
    };

    const updateLayout = () => {
      const width = layout.clientWidth;

      if (!width) {
        layout.style.height = `${tileSize}px`;
        return;
      }

      const columns = Math.max(1, Math.floor(width / tileStride));
      const rows = Math.ceil(tiles.length / columns);
      const gridWidth = columns * tileStride;
      const startOffset = Math.max(0, Math.floor((width - gridWidth) / 2));

      tiles.forEach((tile, index) => {
        const column = index % columns;
        const row = Math.floor(index / columns);
        const visualLeft = startOffset + column * tileStride;
        const visualTop = row * tileStride;

        tile.style.left = `${visualLeft - tileMargin}px`;
        tile.style.top = `${visualTop - tileMargin}px`;
        tile.dataset.left = `${visualLeft}`;
        tile.dataset.top = `${visualTop}`;
      });

      layout.style.height = `${Math.max(rows * tileStride, tileSize)}px`;

      if (activeIndex >= 0) {
        showPreview(activeIndex);
      } else {
        hidePreview();
      }
    };

    tiles.forEach((tile, index) => {
      tile.addEventListener("mouseenter", () => showPreview(index));
      tile.addEventListener("focus", () => showPreview(index));
      tile.addEventListener("click", (event) => {
        if (mobileFullscreenEnabled && mobileQuery.matches) {
          event.preventDefault();
          openViewer(index, tile);
          return;
        }

        showPreview(index);
      });
      tile.addEventListener("blur", () => {
        window.setTimeout(() => {
          if (!root.contains(document.activeElement) && !layout.matches(":hover")) {
            hidePreview();
          }
        }, 0);
      });
    });

    layout.addEventListener("mouseleave", () => {
      if (!root.contains(document.activeElement)) {
        hidePreview();
      }
    });

    if (viewerTrack instanceof HTMLElement) {
      viewerTrack.addEventListener("touchstart", (event) => {
        if (!isViewerOpen() || zoomState.scale > 1.01 || event.touches.length !== 1) {
          viewerSwipeStart = null;
          return;
        }

        const touch = event.touches[0];
        viewerSwipeStart = {
          x: touch.clientX,
          y: touch.clientY
        };
      }, { passive: true });

      viewerTrack.addEventListener("touchmove", (event) => {
        if (event.touches.length > 1) {
          viewerSwipeStart = null;
        }
      }, { passive: true });

      viewerTrack.addEventListener("touchend", (event) => {
        if (!viewerSwipeStart || zoomState.scale > 1.01 || event.changedTouches.length === 0) {
          viewerSwipeStart = null;
          return;
        }

        const touch = event.changedTouches[0];
        const dx = touch.clientX - viewerSwipeStart.x;
        const dy = touch.clientY - viewerSwipeStart.y;
        viewerSwipeStart = null;

        if (Math.abs(dx) >= 48 && Math.abs(dx) > Math.abs(dy) * 1.25) {
          stepViewer(dx < 0 ? 1 : -1);
        }
      }, { passive: true });

      viewerTrack.addEventListener("pointerdown", (event) => {
        if (!isViewerOpen() || zoomState.scale > 1.01 || event.pointerType === "touch") {
          viewerPointerSwipeStart = null;
          return;
        }

        viewerPointerSwipeStart = {
          x: event.clientX,
          y: event.clientY
        };
      });

      viewerTrack.addEventListener("pointerup", (event) => {
        if (!viewerPointerSwipeStart || zoomState.scale > 1.01 || event.pointerType === "touch") {
          viewerPointerSwipeStart = null;
          return;
        }

        const dx = event.clientX - viewerPointerSwipeStart.x;
        const dy = event.clientY - viewerPointerSwipeStart.y;
        viewerPointerSwipeStart = null;

        if (Math.abs(dx) >= 48 && Math.abs(dx) > Math.abs(dy) * 1.25) {
          stepViewer(dx < 0 ? 1 : -1);
        }
      });

      viewerTrack.addEventListener("pointercancel", () => {
        viewerPointerSwipeStart = null;
      });
    }

    if (viewerZoomFrame instanceof HTMLElement) {
      const finishPointer = (event) => {
        zoomInteraction.pointers.delete(event.pointerId);

        if (viewerZoomFrame.hasPointerCapture?.(event.pointerId)) {
          viewerZoomFrame.releasePointerCapture(event.pointerId);
        }

        if (zoomInteraction.pointers.size >= 2) {
          const pair = getPointerPair();

          if (pair) {
            const [first, second] = pair;
            zoomInteraction.pinchDistance = Math.hypot(second.x - first.x, second.y - first.y);
            zoomInteraction.pinchScale = zoomState.scale;
            zoomInteraction.pinchStartX = zoomState.x;
            zoomInteraction.pinchStartY = zoomState.y;
          }

          return;
        }

        zoomInteraction.pinchDistance = 0;
        viewerZoomFrame.classList.remove("is-dragging");

        if (zoomInteraction.pointers.size === 1 && zoomState.scale > 1.01) {
          const [pointerId, point] = Array.from(zoomInteraction.pointers.entries())[0];
          beginPan(pointerId, point);
          return;
        }

        zoomInteraction.panPointerId = null;

        if (zoomState.scale <= 1.01) {
          resetZoomState();
        }
      };

      viewerZoomFrame.addEventListener("pointerdown", (event) => {
        if (!isViewerOpen()) {
          return;
        }

        zoomInteraction.pointers.set(event.pointerId, { x: event.clientX, y: event.clientY });
        viewerZoomFrame.setPointerCapture?.(event.pointerId);

        if (zoomInteraction.pointers.size >= 2) {
          const pair = getPointerPair();

          if (!pair) {
            return;
          }

          const [first, second] = pair;
          zoomInteraction.pinchDistance = Math.max(1, Math.hypot(second.x - first.x, second.y - first.y));
          zoomInteraction.pinchScale = zoomState.scale;
          zoomInteraction.pinchStartX = zoomState.x;
          zoomInteraction.pinchStartY = zoomState.y;
          zoomInteraction.panPointerId = null;
          event.preventDefault();
          return;
        }

        if (zoomState.scale > 1.01) {
          beginPan(event.pointerId, { x: event.clientX, y: event.clientY });
          viewerZoomFrame.classList.add("is-dragging");
          event.preventDefault();
        }
      });

      viewerZoomFrame.addEventListener("pointermove", (event) => {
        if (!isViewerOpen() || !zoomInteraction.pointers.has(event.pointerId)) {
          return;
        }

        zoomInteraction.pointers.set(event.pointerId, { x: event.clientX, y: event.clientY });

        if (zoomInteraction.pointers.size >= 2) {
          const pair = getPointerPair();

          if (!pair) {
            return;
          }

          const [first, second] = pair;
          const nextDistance = Math.max(1, Math.hypot(second.x - first.x, second.y - first.y));
          const nextScale = clamp(
            zoomInteraction.pinchScale * (nextDistance / Math.max(zoomInteraction.pinchDistance, 1)),
            1,
            4
          );
          const nextOffset = clampZoomOffset(
            zoomInteraction.pinchStartX,
            zoomInteraction.pinchStartY,
            nextScale,
            zoomInteraction.pinchScale
          );

          zoomState.scale = nextScale;
          zoomState.x = nextOffset.x;
          zoomState.y = nextOffset.y;
          applyZoomState();
          event.preventDefault();
          return;
        }

        if (zoomInteraction.panPointerId === event.pointerId && zoomState.scale > 1.01) {
          const nextOffset = clampZoomOffset(
            zoomInteraction.startX + (event.clientX - zoomInteraction.panStartX),
            zoomInteraction.startY + (event.clientY - zoomInteraction.panStartY),
            zoomState.scale
          );

          zoomState.x = nextOffset.x;
          zoomState.y = nextOffset.y;
          applyZoomState();
          event.preventDefault();
        }
      });

      viewerZoomFrame.addEventListener("pointerup", finishPointer);
      viewerZoomFrame.addEventListener("pointercancel", finishPointer);
      viewerZoomFrame.addEventListener("pointerleave", (event) => {
        if (zoomInteraction.pointers.has(event.pointerId)) {
          finishPointer(event);
        }
      });
    }

    viewerPrev?.addEventListener("click", (event) => {
      event.preventDefault();
      stepViewer(-1);
    });
    viewerNext?.addEventListener("click", (event) => {
      event.preventDefault();
      stepViewer(1);
    });
    viewerClose?.addEventListener("click", closeViewer);

    viewerDialog?.addEventListener("click", (event) => {
      if (event.target === viewerDialog) {
        closeViewer();
      }
    });

    viewerDialog?.addEventListener("keydown", (event) => {
      if (event.key === "ArrowLeft") {
        event.preventDefault();
        stepViewer(-1);
      } else if (event.key === "ArrowRight") {
        event.preventDefault();
        stepViewer(1);
      }
    });

    viewerDialog?.addEventListener("close", () => {
      viewerSwipeStart = null;
      viewerPointerSwipeStart = null;
      resetZoomState();

      if (lastFocusedTile instanceof HTMLElement) {
        lastFocusedTile.focus({ preventScroll: true });
      }
    });

    const handleBreakpointChange = () => {
      if (!mobileQuery.matches) {
        closeViewer();
      }

      updateLayout();
    };

    const debouncedUpdate = debounce(() => {
      updateLayout();
    }, 120);

    const containingDetails = root.closest("details");
    containingDetails?.addEventListener("toggle", () => {
      if (containingDetails.open) {
        window.requestAnimationFrame(updateLayout);
      }
    });

    desktopQuery.addEventListener("change", handleBreakpointChange);
    window.addEventListener("resize", debouncedUpdate);
    updateLayout();
    setViewerIndex(0);
  }
</script>
