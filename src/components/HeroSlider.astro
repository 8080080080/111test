---
import type { HeroSlide } from "../types/content";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel: string;
  secondaryHref: string;
  slides: HeroSlide[];
  id?: string;
}

const {
  eyebrow,
  title,
  description,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
  slides,
  id = "hero-slider"
} = Astro.props;
const transparentPixel = "data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==";
---

<section class="section-padding pb-12 pt-10 sm:pb-16 sm:pt-12">
  <div class="container-shell">
    <div class="surface-card overflow-hidden bg-hero-glow">
      <div class="grid gap-8 px-6 py-8 sm:px-8 sm:py-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center lg:px-12 lg:py-14">
        <div class="space-y-6">
          <span class="text-panel-compact inline-flex text-xs font-semibold uppercase tracking-[0.2em] text-bronze">
            {eyebrow}
          </span>
          <div class="space-y-4">
            <h1 class="text-panel inline-block max-w-3xl text-4xl sm:text-5xl lg:text-6xl">{title}</h1>
            <p class="text-panel max-w-2xl text-base sm:text-lg">{description}</p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a class="button-primary" href={primaryHref}>{primaryLabel}</a>
            <a class="button-secondary" href={secondaryHref}>{secondaryLabel}</a>
          </div>
        </div>

        <div id={id} class="relative" data-slider>
          <div class="absolute inset-5 rounded-4xl bg-sage/12 blur-3xl"></div>
          <div class="relative overflow-hidden rounded-4xl border border-white/80 bg-white shadow-soft" data-slider-swipe-area>
            <!--
              slider-track: uses transform (translateX) which is compositor-only — no layout.
              The CSS transition is defined here so prefers-reduced-motion can suppress it
              without JavaScript needing to know about it.
            -->
            <div class="slider-track flex" data-slider-track>
              {slides.map((slide, index) => (
                <figure class="min-w-full" data-slide>
                  <div class="aspect-[5/4] overflow-hidden bg-shell">
                    <img
                      class="h-full w-full object-cover"
                      src={index === 0 ? slide.image : transparentPixel}
                      alt={slide.alt}
                      width={slide.width ?? 800}
                      height={slide.height ?? 640}
                      loading={index === 0 ? "eager" : "lazy"}
                      decoding={index === 0 ? "sync" : "async"}
                      fetchpriority={index === 0 ? "high" : "low"}
                      data-slider-image
                      data-src={index === 0 ? undefined : slide.image}
                    />
                  </div>
                </figure>
              ))}
            </div>
            <button
              class="absolute left-3 top-1/2 z-10 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-white/25 bg-ink/82 text-white shadow-[0_18px_40px_rgba(26,25,23,0.28)] backdrop-blur-md transition hover:bg-bronze focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-ink active:scale-[0.98] sm:left-4 sm:h-14 sm:w-14"
              type="button"
              data-slider-prev
              aria-label="წინა ფოტო"
            >
              <svg aria-hidden="true" class="h-5 w-5 sm:h-6 sm:w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 18l-6-6 6-6"></path>
              </svg>
            </button>
            <button
              class="absolute right-3 top-1/2 z-10 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-white/25 bg-ink/82 text-white shadow-[0_18px_40px_rgba(26,25,23,0.28)] backdrop-blur-md transition hover:bg-bronze focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-ink active:scale-[0.98] sm:right-4 sm:h-14 sm:w-14"
              type="button"
              data-slider-next
              aria-label="შემდეგი ფოტო"
            >
              <svg aria-hidden="true" class="h-5 w-5 sm:h-6 sm:w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 18l6-6-6-6"></path>
              </svg>
            </button>
          </div>

          <div class="mt-5 px-1 sm:px-2">
            <div class="flex w-full items-center justify-between gap-2 sm:gap-3" aria-label="მთავარი ფოტო სლაიდები">
              {slides.map((slide, index) => (
                <button
                  class={`h-2.5 rounded-full bg-ink/20 ${index === 0 ? "w-10 bg-bronze" : "w-2.5"}`}
                  type="button"
                  data-slider-dot
                  data-index={index}
                  aria-label={`გადადი ფოტოზე ${index + 1}: ${slide.alt}`}
                  aria-current={index === 0 ? "true" : "false"}
                ></button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!--
  Slider track CSS: defined in a <style> block so it's scoped and can use
  @media (prefers-reduced-motion) to kill the transition at the CSS level,
  independent of the JS logic.
-->
<style>
  .slider-track {
    transition: transform 700ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  @media (prefers-reduced-motion: reduce) {
    .slider-track {
      transition: none;
    }
  }
</style>

<script>
  import { attachMobileSwipeNavigation } from "../lib/mobileSwipeNavigation";

  document.querySelectorAll<HTMLElement>("[data-slider]").forEach((root) => {
    if (root.dataset.sliderReady) {
      return;
    }

    root.dataset.sliderReady = "true";

    const swipeArea = root.querySelector<HTMLElement>("[data-slider-swipe-area]");
    const track = root.querySelector<HTMLElement>("[data-slider-track]");
    const slides = Array.from(root.querySelectorAll<HTMLElement>("[data-slide]"));
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-slider-dot]"));
    const previous = root.querySelector<HTMLButtonElement>("[data-slider-prev]");
    const next = root.querySelector<HTMLButtonElement>("[data-slider-next]");

    if (!track || slides.length === 0) {
      return;
    }

    let index = 0;
    let timer = 0;
    let isPaused = false;

    // Respect prefers-reduced-motion in JS too: skip autoplay entirely
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const modulo = (value, length) => (value % length + length) % length;

    const ensureSlideImage = (slideIndex) => {
      const image = slides[modulo(slideIndex, slides.length)]?.querySelector("[data-slider-image]");

      if (!(image instanceof HTMLImageElement)) {
        return;
      }

      const nextSrc = image.dataset.src;

      if (!nextSrc) {
        return;
      }

      image.loading = "eager";
      image.src = nextSrc;
      delete image.dataset.src;
    };

    const update = (nextIndex) => {
      index = modulo(nextIndex, slides.length);
      ensureSlideImage(index);
      ensureSlideImage(index + 1);
      ensureSlideImage(index - 1);
      track.style.transform = `translateX(-${index * 100}%)`;

      dots.forEach((dot, dotIndex) => {
        dot.classList.toggle("w-10", dotIndex === index);
        dot.classList.toggle("w-2.5", dotIndex !== index);
        dot.classList.toggle("bg-bronze", dotIndex === index);
        dot.classList.toggle("bg-ink/20", dotIndex !== index);
        dot.setAttribute("aria-current", dotIndex === index ? "true" : "false");
      });
    };

    const clearTimer = () => {
      window.clearTimeout(timer);
      timer = 0;
    };

    const scheduleNext = () => {
      clearTimer();

      // No autoplay for reduced-motion users or when document is hidden
      if (prefersReduced || isPaused || document.hidden) {
        return;
      }

      timer = window.setTimeout(() => {
        update(index + 1);
        scheduleNext();
      }, 5000);
    };

    const pause = () => {
      isPaused = true;
      clearTimer();
    };

    const resume = () => {
      isPaused = false;
      scheduleNext();
    };

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        update(Number(dot.dataset.index));
        scheduleNext();
      });
    });

    previous?.addEventListener("click", () => {
      update(index - 1);
      scheduleNext();
    });

    next?.addEventListener("click", () => {
      update(index + 1);
      scheduleNext();
    });

    attachMobileSwipeNavigation(swipeArea, {
      isEnabled: () => slides.length > 1,
      shouldIgnore: (target) =>
        target instanceof Element &&
        Boolean(target.closest("[data-slider-prev], [data-slider-next], [data-slider-dot]")),
      onSwipe: (direction) => {
        update(index + direction);
        scheduleNext();
      }
    });

    root.addEventListener("mouseenter", pause);
    root.addEventListener("mouseleave", resume);
    root.addEventListener("touchstart", pause, { passive: true });
    root.addEventListener("touchend", resume, { passive: true });
    root.addEventListener("touchcancel", resume, { passive: true });

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) {
        clearTimer();
        return;
      }

      scheduleNext();
    });

    update(0);
    scheduleNext();
  });
</script>
