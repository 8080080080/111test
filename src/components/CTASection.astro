---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  eyebrow,
  title,
  description,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref
} = Astro.props;
---

<section class="section-padding">
  <div class="container-shell">
    <div class="surface-card overflow-hidden bg-ink text-mist">
      <div class="grid gap-8 px-6 py-10 sm:px-10 lg:grid-cols-[1.4fr_0.8fr] lg:px-12 lg:py-14">
        <div class="space-y-4">
          {eyebrow && <p class="eyebrow text-panel-dark-compact inline-flex w-fit text-sand/90">{eyebrow}</p>}
          <h2 class="text-panel-dark inline-block max-w-3xl text-3xl text-mist sm:text-4xl">{title}</h2>
          <p class="text-panel-dark max-w-2xl text-mist/80">{description}</p>
        </div>
        <div class="flex flex-col gap-3 self-center lg:items-end">
          <a class="button-primary bg-bronze hover:bg-sage" href={primaryHref}>{primaryLabel}</a>
          {secondaryLabel && secondaryHref && (
            <a class="button-secondary border-white/15 bg-white/10 text-mist hover:bg-white/16" href={secondaryHref}>
              {secondaryLabel}
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</section>

