---
import FAQSection from "./FAQSection.astro";
import HeroSlider from "./HeroSlider.astro";
import SectionHeading from "./SectionHeading.astro";
import type { SiteData } from "../types/content";

interface Props {
  site: SiteData;
  phoneHref: string;
}

const { site, phoneHref } = Astro.props;
---

<!-- Generated from Figma node 1:3 and adapted to this Astro codebase. -->
<HeroSlider
  eyebrow={site.hero.eyebrow}
  title={site.hero.title}
  description={site.hero.description}
  primaryLabel={site.hero.primaryLabel}
  primaryHref={site.hero.primaryHref}
  secondaryLabel={site.hero.secondaryLabel}
  secondaryHref={site.hero.secondaryHref}
  slides={site.hero.slides}
/>

<section class="bg-white/15 py-10 sm:py-12 lg:py-14">
  <div class="container-shell space-y-8">
    <SectionHeading
      eyebrow="რატომ Winsome"
      title="ადგილობრივი წარმოება, ზუსტი მორგება და მოწესრიგებული შედეგი"
      description="ბრენდის პოზიციონირება ეფუძნება ხარისხიან მასალას, სუფთა მონტაჟს და რეალურ პრაქტიკულობას ქართული საცხოვრებელი და სამუშაო სივრცეებისთვის."
    />
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {site.whyChooseUs.map((item) => (
        <article class="surface-card p-6">
          <h3 class="text-2xl">{item.title}</h3>
          <p class="mt-3">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="py-10 sm:py-12 lg:py-14">
  <div class="container-shell space-y-8">
    <SectionHeading
      eyebrow="პროცესი"
      title="მარტივი გზა კონსულტაციიდან საბოლოო მონტაჟამდე"
      description="გამჭვირვალე და მშვიდი პროცესი ბინებისთვის, ოფისებისთვის და კომერციული პროექტებისთვის თბილისში და საქართველოს მასშტაბით."
    />
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {site.process.map((step, index) => (
        <article class="surface-card p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-bronze">0{index + 1}</p>
          <h3 class="mt-4 text-2xl">{step.title}</h3>
          <p class="mt-3">{step.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<FAQSection
  compact
  eyebrow="კითხვები"
  title="კითხვები, რომლებსაც მომხმარებლები შეთავაზებამდე ყველაზე ხშირად სვამენ"
  align="center"
  stackCta
  faqs={site.homeFaqs}
  ctaLabel="ყველა FAQ"
  ctaHref="/faq/"
/>

<section class="py-8 sm:py-10">
  <div class="container-shell">
    <div class="surface-card flex flex-col gap-6 px-6 py-8 sm:px-8 lg:flex-row lg:items-center lg:justify-between lg:px-12">
      <div class="space-y-2">
        <p class="eyebrow">პირდაპირი კონტაქტი</p>
        <h2 class="text-3xl">გჭირდება სწრაფი პასუხი პროდუქტის, ზომების ან მონტაჟის შესახებ?</h2>
        <p>დაგვირეკე პირდაპირ ან გამოგვიგზავნე მოთხოვნა ოთახის ტიპით, ფოტოებით და მიახლოებითი ზომებით.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a class="button-primary" href={phoneHref}>დარეკე {site.phone}</a>
        <a class="button-secondary" href="/contact/">კონტაქტის გვერდი</a>
      </div>
    </div>
  </div>
</section>
