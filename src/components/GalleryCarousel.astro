---
import type { GalleryItem } from "../types/content";

interface Props {
  item: GalleryItem;
  locale?: "ka" | "en";
}

const { item, locale = "en" } = Astro.props;

const images =
  item.images && item.images.length > 0
    ? item.images.map((img) => ({ src: img.src, alt: img.alt, width: img.width, height: img.height }))
    : [{ src: item.image, alt: item.alt, width: 1200, height: 900 }];

const hasMultiple = images.length > 1;
const id = item.id;

const labels =
  locale === "ka"
    ? {
        close: "დახურვა",
        prev: "წინა ფოტო",
        next: "შემდეგი ფოტო",
        open: `ფოტოების ნახვა: ${item.title}`,
        dialog: `პროექტის ფოტოები: ${item.title}`,
        dot: "ფოტოზე გადასვლა"
      }
    : {
        close: "Close",
        prev: "Previous photo",
        next: "Next photo",
        open: `View photos: ${item.title}`,
        dialog: `Project photos: ${item.title}`,
        dot: "Go to photo"
      };

const titleId = `${id}-viewer-title`;
---

<!-- Card thumbnail -->
<button
  class="gallery-thumb block w-full text-left"
  type="button"
  data-project-viewer-trigger={id}
  aria-haspopup="dialog"
  aria-label={labels.open}
>
  <div class="aspect-[4/3] overflow-hidden bg-shell">
    <img
      class="gallery-img h-full w-full object-cover"
      src={item.image}
      alt={item.alt}
      width="1200"
      height="900"
      loading="lazy"
      decoding="async"
    />
  </div>
</button>

<!-- Opened project viewer -->
<dialog
  class="project-viewer-dialog"
  data-project-viewer-dialog={id}
  aria-labelledby={titleId}
  aria-label={labels.dialog}
>
  <div class="project-viewer-shell" data-project-viewer-shell>
    <div class="project-viewer-panel">
      <header class="project-viewer-header">
        <div class="min-w-0">
          <p class="project-viewer-meta">{item.category} • {item.location}</p>
          <h2 id={titleId} class="project-viewer-title">{item.title}</h2>
          <p class="project-viewer-count" data-project-viewer-count aria-live="polite" aria-atomic="true">
            1 / {images.length}
          </p>
        </div>

        <button
          class="project-viewer-close"
          type="button"
          data-project-viewer-close
          aria-label={labels.close}
        >
          <svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6L6 18M6 6l12 12" />
          </svg>
        </button>
      </header>

      <div class="project-viewer-stage">
        <div class="project-viewer-viewport" data-project-viewer-viewport>
          <div class="project-viewer-track" data-project-viewer-track>
            {images.map((img, index) => (
              <figure
                class="project-viewer-slide"
                role="group"
                aria-roledescription="slide"
                aria-label={`${index + 1} / ${images.length}`}
              >
                <div class="project-viewer-image-frame" data-project-viewer-zoom-frame>
                  <img
                    class="project-viewer-image"
                    data-project-viewer-zoom-image
                    src={img.src}
                    alt={img.alt}
                    width={img.width}
                    height={img.height}
                    loading={index === 0 ? "eager" : "lazy"}
                    decoding="async"
                  />
                </div>
              </figure>
            ))}
          </div>
        </div>

        {hasMultiple && (
          <>
            <button
              class="project-viewer-nav project-viewer-prev"
              type="button"
              data-project-viewer-prev
              aria-label={labels.prev}
            >
              <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 18l-6-6 6-6" />
              </svg>
            </button>
            <button
              class="project-viewer-nav project-viewer-next"
              type="button"
              data-project-viewer-next
              aria-label={labels.next}
            >
              <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 18l6-6-6-6" />
              </svg>
            </button>
          </>
        )}
      </div>

      {hasMultiple && (
        <div class="project-viewer-dots" data-project-viewer-dots>
          {images.map((_, index) => (
            <button
              class="project-viewer-dot"
              type="button"
              data-project-viewer-dot={index}
              data-active={index === 0 ? "" : undefined}
              aria-label={`${labels.dot} ${index + 1}`}
              aria-current={index === 0 ? "true" : undefined}
            />
          ))}
        </div>
      )}
    </div>
  </div>
</dialog>

<style>
  .gallery-thumb {
    cursor: zoom-in;
  }

  .project-viewer-dialog {
    width: min(94vw, 76rem);
    max-width: none;
    max-height: none;
    margin: auto;
    padding: 0;
    border: 0;
    overflow: visible;
    color: #1a1917;
    background: transparent;
  }

  .project-viewer-dialog::backdrop {
    background: rgba(20, 24, 33, 0.68);
  }

  .project-viewer-dialog[open] {
    animation: project-viewer-in 220ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .project-viewer-dialog[open]::backdrop {
    animation: project-viewer-backdrop-in 180ms ease both;
  }

  .project-viewer-shell {
    display: flex;
    min-height: 100%;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 3vw, 2rem);
  }

  .project-viewer-panel {
    display: flex;
    width: 100%;
    max-height: min(92dvh, 54rem);
    min-height: 0;
    flex-direction: column;
    gap: clamp(0.85rem, 2vw, 1.25rem);
    overflow: hidden;
    border: 1px solid rgba(26, 25, 23, 0.08);
    border-radius: 2rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(249, 250, 255, 0.96)),
      #ffffff;
    box-shadow:
      0 34px 90px -44px rgba(26, 25, 23, 0.42),
      inset 0 1px 0 rgba(255, 255, 255, 0.84);
    padding: clamp(0.95rem, 2.2vw, 1.55rem);
  }

  .project-viewer-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: start;
  }

  .project-viewer-meta {
    margin: 0;
    color: #2f2482;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .project-viewer-title {
    margin-top: 0.25rem;
    color: #1a1917;
    font-size: clamp(1.2rem, 1.4vw + 0.9rem, 2rem);
    line-height: 1.16;
  }

  .project-viewer-count {
    margin: 0.35rem 0 0;
    color: rgba(26, 25, 23, 0.52);
    font-size: 0.84rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .project-viewer-close,
  .project-viewer-nav {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(47, 36, 130, 0.14);
    border-radius: 9999px;
    color: #1a1917;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 12px 30px -22px rgba(26, 25, 23, 0.38);
    cursor: pointer;
  }

  .project-viewer-close {
    width: 2.55rem;
    height: 2.55rem;
    flex: 0 0 auto;
  }

  .project-viewer-stage {
    position: relative;
    min-height: 0;
    flex: 1 1 auto;
  }

  .project-viewer-viewport {
    height: clamp(20rem, 62dvh, 42rem);
    overflow: hidden;
    border: 1px solid rgba(26, 25, 23, 0.06);
    border-radius: 1.45rem;
    background: #f4f6fb;
  }

  .project-viewer-track {
    display: flex;
    height: 100%;
    user-select: none;
    touch-action: pan-y pinch-zoom;
  }

  .project-viewer-slide {
    display: flex;
    min-width: 0;
    min-height: 100%;
    flex: 0 0 100%;
    margin: 0;
  }

  .project-viewer-image-frame {
    display: flex;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: clamp(0.35rem, 1vw, 0.75rem);
  }

  .project-viewer-image {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    transform: translate3d(var(--zoom-x, 0px), var(--zoom-y, 0px), 0) scale(var(--zoom-scale, 1));
    transform-origin: center center;
    transition: transform 180ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-viewer-image[data-zoomed] {
    will-change: transform;
  }

  .project-viewer-image-frame[data-zoom-gesturing] .project-viewer-image {
    transition: none;
  }

  .project-viewer-nav {
    position: absolute;
    top: 50%;
    width: 2.8rem;
    height: 2.8rem;
    transform: translateY(-50%);
  }

  .project-viewer-prev {
    left: clamp(0.55rem, 1.5vw, 1rem);
  }

  .project-viewer-next {
    right: clamp(0.55rem, 1.5vw, 1rem);
  }

  .project-viewer-close:hover,
  .project-viewer-nav:hover:not(:disabled) {
    background: #ffffff;
    transform: translateY(-1px);
  }

  .project-viewer-nav:hover:not(:disabled) {
    transform: translateY(calc(-50% - 1px));
  }

  .project-viewer-close:active {
    transform: translateY(1px);
  }

  .project-viewer-nav:active:not(:disabled) {
    transform: translateY(calc(-50% + 1px));
  }

  .project-viewer-nav:disabled {
    opacity: 0.34;
    cursor: default;
  }

  .project-viewer-dots {
    display: flex;
    min-height: 1.65rem;
    align-items: center;
    justify-content: center;
    gap: 0.52rem;
  }

  .project-viewer-dot {
    position: relative;
    width: 0.46rem;
    height: 0.46rem;
    padding: 0;
    border: 0;
    border-radius: 9999px;
    background: rgba(26, 25, 23, 0.2);
    cursor: pointer;
    transition:
      width 220ms cubic-bezier(0.16, 1, 0.3, 1),
      background-color 220ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-viewer-dot::before {
    content: "";
    position: absolute;
    inset: -0.65rem;
  }

  .project-viewer-dot[data-active] {
    width: 1.55rem;
    background: #2f2482;
  }

  @keyframes project-viewer-in {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.985);
    }
  }

  @keyframes project-viewer-backdrop-in {
    from {
      opacity: 0;
    }
  }

  @media (max-width: 639px) {
    .project-viewer-dialog {
      width: 100vw;
      height: 100dvh;
      margin: 0;
    }

    .project-viewer-shell {
      min-height: 100dvh;
      align-items: stretch;
      padding: 0;
    }

    .project-viewer-panel {
      height: 100dvh;
      max-height: none;
      border: 0;
      border-radius: 0;
      gap: 0.8rem;
      padding:
        calc(0.9rem + env(safe-area-inset-top))
        1rem
        calc(0.8rem + env(safe-area-inset-bottom));
    }

    .project-viewer-header {
      gap: 0.75rem;
    }

    .project-viewer-meta {
      font-size: 0.66rem;
      letter-spacing: 0.16em;
    }

    .project-viewer-title {
      display: -webkit-box;
      margin-top: 0.2rem;
      overflow: hidden;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
      font-size: 1.12rem;
      line-height: 1.22;
    }

    .project-viewer-count {
      margin-top: 0.25rem;
      font-size: 0.78rem;
    }

    .project-viewer-close {
      width: 2.45rem;
      height: 2.45rem;
    }

    .project-viewer-stage {
      display: flex;
      flex-direction: column;
    }

    .project-viewer-viewport {
      height: 100%;
      min-height: 0;
      border-radius: 1.25rem;
    }

    .project-viewer-image-frame {
      padding: 0.45rem;
      touch-action: none;
    }

    .project-viewer-image-frame[data-zoom-active] {
      cursor: grab;
    }

    .project-viewer-nav {
      width: 2.55rem;
      height: 2.55rem;
    }

    .project-viewer-prev {
      left: 0.55rem;
    }

    .project-viewer-next {
      right: 0.55rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-viewer-dialog[open],
    .project-viewer-dialog[open]::backdrop {
      animation: none;
    }

    .project-viewer-close,
    .project-viewer-nav,
    .project-viewer-dot {
      transition: none;
    }
  }
</style>

<script>
  import EmblaCarousel from "embla-carousel";

  interface Point {
    x: number;
    y: number;
  }

  interface ZoomSlideState {
    frame: HTMLElement;
    image: HTMLImageElement;
    pointers: Map<number, Point>;
    scale: number;
    translateX: number;
    translateY: number;
    panStartPoint: Point | null;
    panStartTranslateX: number;
    panStartTranslateY: number;
    pinchStartCenter: Point | null;
    pinchStartDistance: number;
    pinchStartScale: number;
    pinchStartTranslateX: number;
    pinchStartTranslateY: number;
    isPanning: boolean;
    isPinching: boolean;
  }

  interface ZoomController {
    resetAllZoom: (animate?: boolean) => void;
    isAnyZoomed: () => boolean;
  }

  interface ViewerState {
    embla: ReturnType<typeof EmblaCarousel>;
    trigger?: HTMLElement;
    updateUi: () => void;
    resetZoom: (animate?: boolean) => void;
  }

  const viewerMap = new Map<string, ViewerState>();
  const mobileZoomQuery = window.matchMedia("(max-width: 639px) and (pointer: coarse)");
  const maxZoomScale = 3.5;
  const zoomResetThreshold = 1.02;
  let scrollLockDepth = 0;
  let previousBodyOverflow = "";
  let previousDocumentOverflow = "";

  function isMobileZoomAllowed() {
    return mobileZoomQuery.matches;
  }

  function clamp(value: number, min: number, max: number) {
    return Math.min(Math.max(value, min), max);
  }

  function getDistance(a: Point, b: Point) {
    return Math.hypot(a.x - b.x, a.y - b.y);
  }

  function getCenter(a: Point, b: Point): Point {
    return {
      x: (a.x + b.x) / 2,
      y: (a.y + b.y) / 2
    };
  }

  function getRelativePoint(frame: HTMLElement, point: Point): Point {
    const rect = frame.getBoundingClientRect();
    return {
      x: point.x - (rect.left + rect.width / 2),
      y: point.y - (rect.top + rect.height / 2)
    };
  }

  function getPointerPoint(event: PointerEvent): Point {
    return { x: event.clientX, y: event.clientY };
  }

  function shouldHandleZoomPointer(event: PointerEvent) {
    return isMobileZoomAllowed() && event.pointerType === "touch";
  }

  function stopZoomEvent(event: PointerEvent) {
    if (event.cancelable) event.preventDefault();
    event.stopPropagation();
  }

  function clampZoomTranslation(state: ZoomSlideState, x: number, y: number, scale: number): Point {
    const frameRect = state.frame.getBoundingClientRect();
    const imageWidth = state.image.offsetWidth || frameRect.width;
    const imageHeight = state.image.offsetHeight || frameRect.height;
    const maxX = Math.max(0, (imageWidth * scale - frameRect.width) / 2);
    const maxY = Math.max(0, (imageHeight * scale - frameRect.height) / 2);

    return {
      x: clamp(x, -maxX, maxX),
      y: clamp(y, -maxY, maxY)
    };
  }

  function applyZoom(state: ZoomSlideState, scale: number, x: number, y: number, animate = false) {
    const nextScale = clamp(scale, 1, maxZoomScale);
    const nextTranslation = nextScale <= zoomResetThreshold
      ? { x: 0, y: 0 }
      : clampZoomTranslation(state, x, y, nextScale);

    state.scale = nextScale <= zoomResetThreshold ? 1 : nextScale;
    state.translateX = nextTranslation.x;
    state.translateY = nextTranslation.y;
    state.image.style.setProperty("--zoom-scale", state.scale.toFixed(4));
    state.image.style.setProperty("--zoom-x", `${state.translateX.toFixed(2)}px`);
    state.image.style.setProperty("--zoom-y", `${state.translateY.toFixed(2)}px`);

    if (animate) state.frame.removeAttribute("data-zoom-gesturing");

    const isZoomed = state.scale > 1;
    state.frame.toggleAttribute("data-zoom-active", isZoomed);
    state.image.toggleAttribute("data-zoomed", isZoomed);
  }

  function resetZoomState(state: ZoomSlideState, animate = false) {
    state.pointers.clear();
    state.panStartPoint = null;
    state.pinchStartCenter = null;
    state.isPanning = false;
    state.isPinching = false;

    if (!animate) state.frame.setAttribute("data-zoom-gesturing", "");
    applyZoom(state, 1, 0, 0, animate);
    if (!animate) state.frame.removeAttribute("data-zoom-gesturing");
  }

  function captureZoomPointers(state: ZoomSlideState) {
    state.pointers.forEach((_, pointerId) => {
      try {
        state.frame.setPointerCapture(pointerId);
      } catch {
        // Pointer capture can fail if the browser has already released it.
      }
    });
  }

  function releaseZoomPointer(state: ZoomSlideState, pointerId: number) {
    try {
      state.frame.releasePointerCapture(pointerId);
    } catch {
      // The pointer may already be released by the browser.
    }
  }

  function getFirstTwoPointers(state: ZoomSlideState): [Point, Point] | null {
    const points = Array.from(state.pointers.values());
    if (points.length < 2) return null;
    return [points[0], points[1]];
  }

  function startPinch(state: ZoomSlideState) {
    const points = getFirstTwoPointers(state);
    if (!points) return;

    const center = getRelativePoint(state.frame, getCenter(points[0], points[1]));
    state.pinchStartCenter = center;
    state.pinchStartDistance = Math.max(1, getDistance(points[0], points[1]));
    state.pinchStartScale = state.scale;
    state.pinchStartTranslateX = state.translateX;
    state.pinchStartTranslateY = state.translateY;
    state.isPinching = true;
    state.isPanning = false;
    state.frame.setAttribute("data-zoom-gesturing", "");
    captureZoomPointers(state);
  }

  function continuePinch(state: ZoomSlideState) {
    const points = getFirstTwoPointers(state);
    if (!points || !state.pinchStartCenter) return;

    const center = getRelativePoint(state.frame, getCenter(points[0], points[1]));
    const distance = Math.max(1, getDistance(points[0], points[1]));
    const nextScale = clamp(
      state.pinchStartScale * (distance / state.pinchStartDistance),
      1,
      maxZoomScale
    );
    const scaleRatio = nextScale / state.pinchStartScale;
    const nextX = center.x - (state.pinchStartCenter.x - state.pinchStartTranslateX) * scaleRatio;
    const nextY = center.y - (state.pinchStartCenter.y - state.pinchStartTranslateY) * scaleRatio;

    applyZoom(state, nextScale, nextX, nextY);
  }

  function startPan(state: ZoomSlideState, point: Point) {
    state.panStartPoint = point;
    state.panStartTranslateX = state.translateX;
    state.panStartTranslateY = state.translateY;
    state.isPanning = true;
    state.isPinching = false;
    state.frame.setAttribute("data-zoom-gesturing", "");
  }

  function continuePan(state: ZoomSlideState, point: Point) {
    if (!state.panStartPoint) return;

    const nextX = state.panStartTranslateX + point.x - state.panStartPoint.x;
    const nextY = state.panStartTranslateY + point.y - state.panStartPoint.y;
    applyZoom(state, state.scale, nextX, nextY);
  }

  function initMobileZoom(dialog: HTMLDialogElement): ZoomController {
    const states = Array.from(dialog.querySelectorAll<HTMLElement>("[data-project-viewer-zoom-frame]"))
      .map((frame): ZoomSlideState | null => {
        const image = frame.querySelector<HTMLImageElement>("[data-project-viewer-zoom-image]");
        if (!image || !("PointerEvent" in window)) return null;

        const state: ZoomSlideState = {
          frame,
          image,
          pointers: new Map(),
          scale: 1,
          translateX: 0,
          translateY: 0,
          panStartPoint: null,
          panStartTranslateX: 0,
          panStartTranslateY: 0,
          pinchStartCenter: null,
          pinchStartDistance: 1,
          pinchStartScale: 1,
          pinchStartTranslateX: 0,
          pinchStartTranslateY: 0,
          isPanning: false,
          isPinching: false
        };

        frame.addEventListener("pointerdown", (event) => {
          if (!shouldHandleZoomPointer(event)) return;

          const point = getPointerPoint(event);
          state.pointers.set(event.pointerId, point);

          if (state.pointers.size >= 2) {
            stopZoomEvent(event);
            startPinch(state);
            return;
          }

          if (state.scale > 1) {
            stopZoomEvent(event);
            captureZoomPointers(state);
            startPan(state, point);
          }
        }, { capture: true });

        frame.addEventListener("pointermove", (event) => {
          if (!shouldHandleZoomPointer(event) || !state.pointers.has(event.pointerId)) return;

          state.pointers.set(event.pointerId, getPointerPoint(event));

          if (state.pointers.size >= 2) {
            stopZoomEvent(event);
            if (!state.isPinching) startPinch(state);
            continuePinch(state);
            return;
          }

          if (state.scale > 1 && state.isPanning) {
            stopZoomEvent(event);
            continuePan(state, getPointerPoint(event));
          }
        }, { capture: true });

        const finishPointer = (event: PointerEvent) => {
          if (!shouldHandleZoomPointer(event) || !state.pointers.has(event.pointerId)) return;

          const handledZoom = state.isPinching || state.isPanning || state.scale > 1;
          state.pointers.delete(event.pointerId);
          releaseZoomPointer(state, event.pointerId);

          if (state.pointers.size >= 2) {
            startPinch(state);
          } else if (state.pointers.size === 1 && state.scale > 1) {
            const [remainingPoint] = Array.from(state.pointers.values());
            startPan(state, remainingPoint);
          } else {
            state.isPinching = false;
            state.isPanning = false;
            state.frame.removeAttribute("data-zoom-gesturing");
            if (state.scale <= zoomResetThreshold) resetZoomState(state, true);
            else applyZoom(state, state.scale, state.translateX, state.translateY, true);
          }

          if (handledZoom) stopZoomEvent(event);
        };

        frame.addEventListener("pointerup", finishPointer, { capture: true });
        frame.addEventListener("pointercancel", finishPointer, { capture: true });
        frame.addEventListener("lostpointercapture", (event) => {
          state.pointers.delete(event.pointerId);
          if (state.pointers.size === 0) {
            state.isPinching = false;
            state.isPanning = false;
            state.frame.removeAttribute("data-zoom-gesturing");
          }
        });

        return state;
      })
      .filter((state): state is ZoomSlideState => Boolean(state));

    return {
      resetAllZoom(animate = false) {
        states.forEach((state) => resetZoomState(state, animate));
      },
      isAnyZoomed() {
        return states.some((state) => state.scale > 1);
      }
    };
  }

  function lockPageScroll() {
    if (scrollLockDepth === 0) {
      previousBodyOverflow = document.body.style.overflow;
      previousDocumentOverflow = document.documentElement.style.overflow;
      document.body.style.overflow = "hidden";
      document.documentElement.style.overflow = "hidden";
    }

    scrollLockDepth += 1;
  }

  function unlockPageScroll() {
    scrollLockDepth = Math.max(0, scrollLockDepth - 1);

    if (scrollLockDepth === 0) {
      document.body.style.overflow = previousBodyOverflow;
      document.documentElement.style.overflow = previousDocumentOverflow;
    }
  }

  function initViewer(dialog: HTMLDialogElement, id: string): ViewerState | null {
    const cached = viewerMap.get(id);
    if (cached) return cached;

    const viewport = dialog.querySelector<HTMLElement>("[data-project-viewer-viewport]");
    if (!viewport) return null;

    let zoomController: ZoomController = {
      resetAllZoom() {},
      isAnyZoomed() {
        return false;
      }
    };

    const embla = EmblaCarousel(viewport, {
      align: "center",
      containScroll: "trimSnaps",
      dragFree: false,
      loop: false,
      skipSnaps: false,
      watchDrag: () => !zoomController.isAnyZoomed()
    });

    const prevButton = dialog.querySelector<HTMLButtonElement>("[data-project-viewer-prev]");
    const nextButton = dialog.querySelector<HTMLButtonElement>("[data-project-viewer-next]");
    const count = dialog.querySelector<HTMLElement>("[data-project-viewer-count]");
    const dots = Array.from(dialog.querySelectorAll<HTMLButtonElement>("[data-project-viewer-dot]"));
    const slides = Array.from(dialog.querySelectorAll<HTMLElement>(".project-viewer-slide"));
    zoomController = initMobileZoom(dialog);

    function updateUi() {
      const selected = embla.selectedScrollSnap();
      const total = embla.scrollSnapList().length;

      if (prevButton) prevButton.disabled = !embla.canScrollPrev();
      if (nextButton) nextButton.disabled = !embla.canScrollNext();
      if (count) count.textContent = `${selected + 1} / ${total}`;

      slides.forEach((slide, index) => {
        slide.toggleAttribute("aria-hidden", index !== selected);
      });

      dots.forEach((dot, i) => {
        const isActive = i === selected;
        dot.toggleAttribute("data-active", isActive);
        if (isActive) dot.setAttribute("aria-current", "true");
        else dot.removeAttribute("aria-current");
      });
    }

    prevButton?.addEventListener("click", () => embla.scrollPrev());
    nextButton?.addEventListener("click", () => embla.scrollNext());
    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => embla.scrollTo(index));
    });

    dialog.addEventListener("keydown", (e) => {
      if (!dialog.open) return;

      if (e.key === "ArrowLeft") {
        e.preventDefault();
        embla.scrollPrev();
      }

      if (e.key === "ArrowRight") {
        e.preventDefault();
        embla.scrollNext();
      }
    });

    embla.on("select", () => {
      zoomController.resetAllZoom(false);
      updateUi();
    });
    embla.on("reInit", updateUi);

    const state = {
      embla,
      updateUi,
      resetZoom: zoomController.resetAllZoom
    };
    viewerMap.set(id, state);
    updateUi();

    return state;
  }

  document.querySelectorAll<HTMLDialogElement>("[data-project-viewer-dialog]").forEach((dialog) => {
    const id = dialog.dataset.projectViewerDialog;
    if (!id) return;

    dialog.querySelector<HTMLButtonElement>("[data-project-viewer-close]")?.addEventListener("click", () => {
      dialog.close();
    });

    dialog.addEventListener("click", (e) => {
      const target = e.target;
      if (target === dialog || (target instanceof HTMLElement && target.hasAttribute("data-project-viewer-shell"))) {
        dialog.close();
      }
    });

    dialog.addEventListener("close", () => {
      unlockPageScroll();

      const state = viewerMap.get(id);
      state?.resetZoom(false);
      state?.embla.scrollTo(0, true);
      state?.updateUi();
      state?.trigger?.focus({ preventScroll: true });
    });
  });

  document.querySelectorAll<HTMLButtonElement>("[data-project-viewer-trigger]").forEach((trigger) => {
    const id = trigger.dataset.projectViewerTrigger;
    if (!id) return;

    const dialog = document.querySelector<HTMLDialogElement>(`[data-project-viewer-dialog="${id}"]`);
    if (!dialog) return;

    trigger.addEventListener("click", () => {
      if (!dialog.open) {
        lockPageScroll();
        try {
          dialog.showModal();
        } catch (error) {
          unlockPageScroll();
          throw error;
        }
      }

      const state = initViewer(dialog, id);
      if (!state) return;

      state.trigger = trigger;
      requestAnimationFrame(() => {
        state.embla.reInit();
        state.updateUi();
      });
    });
  });
</script>
