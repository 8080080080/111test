---
import { getWebpVariantUrl } from "../lib/imageRegistry";
import type { Locale } from "../lib/content";
import type { Product } from "../types/content";

interface Props {
  product: Product;
  locale?: Locale;
}

const { product, locale = "ka" } = Astro.props;
const primaryImage = product.images[0];
const prefix = locale === "en" ? "/en" : "";
const ctaLabel = locale === "en" ? "Details" : "დეტალურად";
const cardSizes = "(min-width: 1280px) 28rem, (min-width: 768px) 50vw, 100vw";
const cardSrcSet = `${primaryImage.src} ${primaryImage.width}w`;
const cardWebp = getWebpVariantUrl(primaryImage.src);
---

<article class="surface-card group overflow-hidden">
  <a class="block" href={`${prefix}/products/${product.slug}/`}>
    <div class="aspect-[4/3] overflow-hidden bg-shell">
      <picture>
        {cardWebp && <source srcset={`${cardWebp} ${primaryImage.width}w`} type="image/webp" sizes={cardSizes} />}
        <img
          class="card-img h-full w-full object-cover"
          src={primaryImage.src}
          srcset={cardSrcSet}
          sizes={cardSizes}
          alt={primaryImage.alt}
          width={primaryImage.width}
          height={primaryImage.height}
          loading="lazy"
          decoding="async"
        />
      </picture>
    </div>
    <div class="space-y-4 p-6">
      <div class="space-y-2">
        <h3 class="text-panel inline-block text-2xl">{product.name}</h3>
        <p class="text-panel">{product.shortDescription}</p>
      </div>
      <span class="text-panel-compact inline-flex items-center gap-2 text-sm font-semibold text-bronze">
        {ctaLabel}
        <span aria-hidden="true">→</span>
      </span>
    </div>
  </a>
</article>

<style>
  /* Scale is compositor-only (transform). The overflow:hidden parent clips
     the scaled image without triggering layout. Only enable for users who
     haven't requested reduced motion. */
  @media (prefers-reduced-motion: no-preference) {
    .card-img {
      transition: transform 500ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .group:hover .card-img {
      transform: scale(1.03);
    }
  }
</style>
