---
import type { ProductColorCollection } from "../types/content";

interface Props {
  collections: ProductColorCollection[];
  id?: string;
}

const { collections, id = "grouped-color-catalog" } = Astro.props;
---

<div id={id} class="space-y-8 sm:space-y-10" data-grouped-color-catalog>
  {collections.map((collection, collectionIndex) => {
    const layout = collection.layout ?? "fabric";
    const isPattern = layout === "pattern";
    const isSheet = layout === "sheet";
    const sectionClasses =
      collectionIndex % 2 === 0
        ? "space-y-5"
        : "space-y-5 rounded-[2rem] bg-shell/70 p-5 sm:p-6";
    const gridClasses = isPattern
      ? "grid grid-cols-2 gap-4 sm:grid-cols-3 xl:grid-cols-4"
      : isSheet
        ? "grid gap-4 sm:grid-cols-2 xl:grid-cols-3"
        : "grid gap-4 sm:grid-cols-2 xl:grid-cols-3";
    const frameAspect = isPattern ? "aspect-square" : isSheet ? "aspect-[67/78]" : "aspect-[2.75/1]";
    const imageFit = isSheet ? "object-contain" : "object-cover";

    return (
      <section class={sectionClasses}>
        <div class="space-y-2">
          <h3 class="text-panel inline-block text-3xl sm:text-4xl">{collection.name}</h3>
          <p class="text-sm text-ink/55">{isSheet ? "კატალოგის გვერდები" : "ფერების არჩევანი"}</p>
        </div>

        <div class={gridClasses}>
          {collection.items.map((item, itemIndex) => (
            <button
              type="button"
              class="group space-y-2 text-left"
              data-catalog-item
              data-collection={collection.name}
              data-code={item.code}
              data-src={item.src}
              data-alt={item.alt}
              aria-label={`${collection.name} - ${item.code}`}
            >
              <div class="rounded-[1.35rem] border border-black/8 bg-white p-1.5 shadow-[0_18px_36px_rgba(26,25,23,0.08)] transition duration-200 group-hover:-translate-y-1 group-hover:shadow-[0_24px_40px_rgba(26,25,23,0.12)] group-focus-visible:-translate-y-1 group-focus-visible:outline-none group-focus-visible:ring-2 group-focus-visible:ring-bronze">
                <div class={`overflow-hidden rounded-[1rem] bg-shell ${frameAspect}`}>
                  <img
                    class={`h-full w-full transition duration-300 group-hover:scale-[1.02] ${imageFit}`}
                    src={item.src}
                    alt={item.alt}
                    width={item.width}
                    height={item.height}
                    loading={collectionIndex === 0 && itemIndex < 3 ? "eager" : "lazy"}
                    decoding="async"
                  />
                </div>
              </div>
              <p class="px-1 text-sm font-semibold tracking-[0.08em] text-ink/78">{item.code}</p>
            </button>
          ))}
        </div>
      </section>
    );
  })}

  <dialog class="w-[min(96vw,72rem)] rounded-[2rem] border border-black/6 bg-white p-0 shadow-soft backdrop:bg-black/60" data-catalog-dialog>
    <div class="space-y-4 p-4 sm:p-6">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div class="space-y-1">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-bronze" data-catalog-dialog-group></p>
          <p class="text-2xl text-ink" data-catalog-dialog-code></p>
        </div>
        <button class="button-secondary !px-4 !py-2" type="button" data-catalog-dialog-close>დახურვა</button>
      </div>

      <div class="overflow-hidden rounded-[1.5rem] border border-black/6 bg-shell/70 p-2 sm:p-3">
        <img class="block h-auto w-full rounded-[1.15rem]" data-catalog-dialog-image alt="" />
      </div>

      <p class="text-sm text-ink/62" data-catalog-dialog-caption></p>
    </div>
  </dialog>
</div>

<script define:vars={{ catalogId: id }}>
  const root = document.getElementById(catalogId);

  if (root) {
    const dialog = root.querySelector("[data-catalog-dialog]");
    const dialogImage = root.querySelector("[data-catalog-dialog-image]");
    const dialogGroup = root.querySelector("[data-catalog-dialog-group]");
    const dialogCode = root.querySelector("[data-catalog-dialog-code]");
    const dialogCaption = root.querySelector("[data-catalog-dialog-caption]");
    const closeButton = root.querySelector("[data-catalog-dialog-close]");
    const items = Array.from(root.querySelectorAll("[data-catalog-item]"));

    const openDialog = (button) => {
      if (!(dialog instanceof HTMLDialogElement) || !(dialogImage instanceof HTMLImageElement)) {
        return;
      }

      const src = button.getAttribute("data-src") || "";
      const alt = button.getAttribute("data-alt") || "";
      const collection = button.getAttribute("data-collection") || "";
      const code = button.getAttribute("data-code") || "";

      dialogImage.src = src;
      dialogImage.alt = alt;

      if (dialogGroup instanceof HTMLElement) {
        dialogGroup.textContent = collection;
      }

      if (dialogCode instanceof HTMLElement) {
        dialogCode.textContent = code;
      }

      if (dialogCaption instanceof HTMLElement) {
        dialogCaption.textContent = alt;
      }

      dialog.showModal();
    };

    items.forEach((item) => {
      item.addEventListener("click", () => openDialog(item));
    });

    closeButton?.addEventListener("click", () => {
      if (dialog instanceof HTMLDialogElement) {
        dialog.close();
      }
    });

    dialog?.addEventListener("click", (event) => {
      if (!(dialog instanceof HTMLDialogElement) || !(event instanceof MouseEvent)) {
        return;
      }

      const bounds = dialog.getBoundingClientRect();
      const inside =
        event.clientX >= bounds.left &&
        event.clientX <= bounds.right &&
        event.clientY >= bounds.top &&
        event.clientY <= bounds.bottom;

      if (!inside) {
        dialog.close();
      }
    });
  }
</script>