---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SEO from "../components/SEO.astro";
import { getSiteData } from "../lib/content";
import { createLocalBusinessSchema } from "../lib/schema";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pathname?: string;
  keywords?: string[];
  noIndex?: boolean;
  schemas?: unknown[];
  /**
   * Optional: src of the LCP image on this page.
   * Pass the hero/product image URL so the browser can preload it
   * before render, preventing a late LCP discovery.
   */
  lcpImageSrc?: string;
}

const site = getSiteData();
const {
  title,
  description,
  image,
  pathname = Astro.url.pathname,
  keywords = [],
  noIndex = false,
  schemas = [],
  lcpImageSrc
} = Astro.props;
const mergedSchemas = [createLocalBusinessSchema(site), ...schemas];
---

<!doctype html>
<html lang="ka">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#cccbd4" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+Georgian:wght@400;500;600;700&family=Noto+Serif+Georgian:wght@400;500;600;700&display=swap"
    />

    <!--
      DNS-prefetch / preconnect for any third-party origins used.
      Currently none — kept as comment for when CDN or analytics is added.
    -->

    <!--
      LCP image preload: only emitted when the page knows its above-the-fold image.
      This eliminates the render-blocking "late image discovery" problem for
      hero slides and product detail pages.
    -->
    {lcpImageSrc && (
      <link
        rel="preload"
        as="image"
        href={lcpImageSrc}
        fetchpriority="high"
      />
    )}

    <link rel="icon" href="/assets/images/winsome-favicon.png" type="image/png" sizes="256x256" />
    <link rel="apple-touch-icon" href="/assets/images/winsome-favicon.png" />
    <SEO
      title={title}
      description={description}
      pathname={pathname}
      image={image}
      keywords={keywords}
      noIndex={noIndex}
      schemas={mergedSchemas}
    />
    <script src="https://mcp.figma.com/mcp/html-to-design/capture.js" async></script>
  </head>
  <body>
    <a class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[60] focus:rounded-full focus:bg-ink focus:px-4 focus:py-2 focus:text-mist" href="#main-content">
      გადადი ძირითად შინაარსზე
    </a>
    <Header currentPath={Astro.url.pathname} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
