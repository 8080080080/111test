---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SEO from "../components/SEO.astro";
import type { Locale } from "../lib/content";
import { getSiteData } from "../lib/content";
import { createLocalBusinessSchema } from "../lib/schema";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pathname?: string;
  keywords?: string[];
  noIndex?: boolean;
  schemas?: unknown[];
  lcpImageSrc?: string;
  locale?: Locale;
}

const {
  title,
  description,
  image,
  pathname = Astro.url.pathname,
  keywords = [],
  noIndex = false,
  schemas = [],
  lcpImageSrc,
  locale = "ka"
} = Astro.props;
const site = getSiteData(locale);
const mergedSchemas = [createLocalBusinessSchema(site), ...schemas];
const fontStylesheetHref =
  "https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;600&family=Noto+Sans+Georgian:wght@400;600&display=optional";
const enableFigmaCapture = import.meta.env.DEV || import.meta.env.PUBLIC_ENABLE_FIGMA_CAPTURE === "true";
const htmlLang = locale === "en" ? "en" : "ka";
const skipLabel = locale === "en" ? "Skip to main content" : "გადადი ძირითად შინაარსზე";
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#EEF2F8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href={fontStylesheetHref} />
    <link rel="stylesheet" href={fontStylesheetHref} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={fontStylesheetHref} /></noscript>

    {lcpImageSrc && (
      <link
        rel="preload"
        as="image"
        href={lcpImageSrc}
        fetchpriority="high"
      />
    )}

    <link rel="icon" href="/assets/images/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/assets/images/favicon.png" />
    <SEO
      title={title}
      description={description}
      pathname={pathname}
      image={image}
      keywords={keywords}
      noIndex={noIndex}
      schemas={mergedSchemas}
      locale={locale}
    />
    {enableFigmaCapture && <script src="https://mcp.figma.com/mcp/html-to-design/capture.js" async></script>}
  </head>
  <body>
    <a class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[60] focus:rounded-full focus:bg-ink focus:px-4 focus:py-2 focus:text-mist" href="#main-content">
      {skipLabel}
    </a>
    <Header currentPath={Astro.url.pathname} locale={locale} />
    <main id="main-content">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
