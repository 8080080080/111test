---
import HomepageBodyFromFigma from "../components/HomepageBodyFromFigma.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPhoneHref, getSiteData } from "../lib/content";
import { createFaqSchema } from "../lib/schema";

const site = getSiteData();
const phoneHref = getPhoneHref(site.phone);
const heroLcpImage = site.hero.slides[0]?.image;
---

<BaseLayout
  title="ჟალუზები და დამცავი ბადეები თბილისში | ადგილობრივი წარმოება"
  description="ინდივიდუალურ ზომაზე მორგებული ჟალუზები და მწერებისგან დამცავი ბადეები თბილისში. ადგილობრივი წარმოება, უფასო კონსულტაცია, პროფესიონალური მონტაჟი. დარეკეთ: 032 2 472 525"
  pathname="/"
  schemas={[createFaqSchema(site.homeFaqs)]}
  lcpImageSrc={heroLcpImage}
>
  <HomepageBodyFromFigma site={site} phoneHref={phoneHref} />
</BaseLayout>

