---
import HomepageBodyFromFigma from "../components/HomepageBodyFromFigma.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPhoneHref, getProducts, getSiteData } from "../lib/content";
import { createFaqSchema } from "../lib/schema";

const site = getSiteData();
const products = getProducts();
const phoneHref = getPhoneHref(site.phone);
const heroLcpImage = site.hero.slides[0]?.image;
---

<BaseLayout
  title="ჟალუზები და დამცავი ბადეები თბილისში"
  description={site.defaultSeo.defaultDescription}
  pathname="/"
  keywords={[...site.defaultSeo.georgianKeywords, ...site.defaultSeo.localIntentKeywords]}
  schemas={[createFaqSchema(site.homeFaqs)]}
  lcpImageSrc={heroLcpImage}
>
  <HomepageBodyFromFigma site={site} products={products} phoneHref={phoneHref} />
</BaseLayout>

