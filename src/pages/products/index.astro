---
import ProductCard from "../../components/ProductCard.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getProducts } from "../../lib/content";
import { createBreadcrumbSchema } from "../../lib/schema";

const products = getProducts();
const breadcrumbs = createBreadcrumbSchema([
  { name: "მთავარი", path: "/" },
  { name: "პროდუქცია", path: "/products/" }
]);
---

<BaseLayout
  title="ჟალუზების და დამცავი ბადეების კატალოგი | Winsome თბილისი"
  description="9 ტიპის ჟალუზი და დამცავი ბადე ინდივიდუალური ზომებით: პლისე, როლეტი, ზებრა, რომაული, ფიჭა, ვერტიკალური, ჰორიზონტალური და მწერებისგან დამცავი სისტემები."
  pathname="/products/"
  schemas={[breadcrumbs]}
>
  <section class="section-padding pb-10">
    <div class="container-shell space-y-8">
      <nav aria-label="Breadcrumb" class="text-panel-compact inline-flex flex-wrap items-center text-sm text-ink/60">
        <a href="/" class="hover:text-bronze">მთავარი</a>
        <span class="mx-2">/</span>
        <span>პროდუქცია</span>
      </nav>
      <SectionHeading
        eyebrow="პროდუქციის მიმოხილვა"
        title="ჟალუზების და დამცავი ბადეების სისტემები ქართული სივრცეებისთვის"
        titleTag="h1"
      />
    </div>
  </section>

  <section class="pb-14 sm:pb-16">
    <div class="container-shell">
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {products.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  <section class="border-t border-black/8 bg-shell/40 pb-16 pt-12 sm:pb-20 sm:pt-16">
    <div class="container-shell max-w-4xl space-y-8">
      <h2 class="text-panel text-3xl sm:text-4xl">როგორ აირჩიოთ ჟალუზი ან დამცავი ბადე თბილისში</h2>
      <div class="space-y-5 text-base leading-relaxed text-ink/85">
        <p>
          თბილისის ბინებში, სახლებსა და ოფისებში ფანჯრის გადაწყვეტა ხშირად განსაზღვრავს კომფორტს: სინათლის რეგულირებას, კონფიდენციალურობას, ენერგოეფექტურობას და ინტერიერის სუფთა ხაზს. Winsome-ში ყველა სისტემა — მათ შორის{" "}
          <strong>პლისე ჟალუზი</strong>, <strong>ფარდა როლეტი</strong>, <strong>ზებრა ჟალუზი</strong>, რომაული, ფიჭა, ვერტიკალური და ჰორიზონტალური ჟალუზი, ასევე{" "}
          <strong>მწერებისგან დამცავი ბადე</strong> — მზადდება ინდივიდუალური ზომებით და მონტაჟდება ადგილზე საქართველოში.
        </p>
        <h3 class="text-xl font-semibold text-ink">შედარება: რომელი სისტემა როდის არის ლოგიკური</h3>
        <p>
          კომპაქტური ღიობები და არასტანდარტული ფორმები ხშირად მოითხოვს პლისეს ან როლეტის მოქნილობას. ფარდა როლეტი და ზებრა ჟალუზი კარგად ერგება მისაღებსა და საძინებელს, სადაც სურვილია სინათლის რბილი რეგულაცია. ვერტიკალური სისტემები ხშირად ირჩევა ფართო ვიტრაჟებზე ან ოფისურ სივრცეებში, ხოლო ჰორიზონტალური ლამელები — კლასიკურ ფანჯრებზე, სადაც საჭიროა ზუსტი ჩრდილის მართვა. მწერებისგან დამცავი ბადე და გოფრირებული ბადის ტიპის კარები კი აუცილებელია აივნის კარებზე და ინტენსიურად გამოყენებად შესასვლელებზე.
        </p>
        <h3 class="text-xl font-semibold text-ink">გაზომვა, კონსულტაცია და მონტაჟი</h3>
        <p>
          სწორი შედეგისთვის მნიშვნელოვანია ღიობის სიგანე, სიმაღლე, პროფილის ტიპი და ინტერიერის შეზღუდვები (კარნიზები, სახელურები, ბატარეები). ჩვენ გთავაზობთ კონსულტაციას, ადგილზე გაზომვას და მონტაჟს — თბილისში და რეგიონებში, სადაც სერვისი ხელმისაწვდომია. ეს ამცირებს შეცდომის რისკს და ზრდის სისტემის სერვის ცხოვრების ვადას.
        </p>
        <p>
          თუ ეძებთ „ჟალუზები თბილისი“, „ფარდა როლეტი“, „ზებრა ჟალუზი“ ან „მწერებისგან დამცავი ბადე“ — დაათვალიერეთ კატალოგის ბარათები, შეარჩიეთ კატეგორია და დაგვიკავშირდით ტელეფონით ან WhatsApp-ით უფასო ორიენტირისთვის. ლოკალური წარმოება ნიშნავს მოქნილ ვადებს და უკეთეს კომუნიკაციას ქართული ბაზრის რეალობის გათვალისწინებით.
        </p>
        <p>
          სერვისის ზონა მოიცავს არა მხოლოდ თბილისს, არამედ რუსთავს, მცხეთას, ბათუმს, ქუთაისსა და გორს — დიდ პროექტებზე და რეზიდენციებზე მუშაობისას ვათვალისწინებთ ლოგისტიკას და მონტაჟის გრაფიკს, რათა პროცესი იყოს გამჭვირვალე დასაწყებიდან ბოლომდე.
        </p>
        <p class="text-ink/70">
          <a class="font-semibold text-bronze hover:underline" href="/contact/">კონტაქტი და ვიზიტი სტუდიოში</a>
          {" "}— გაზომვისა და მონტაჟის დაჯავშნა წინასწარი შეთანხმებით.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
