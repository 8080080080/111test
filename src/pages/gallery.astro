---
import GalleryCarousel from "../components/GalleryCarousel.astro";
import SectionHeading from "../components/SectionHeading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSiteData } from "../lib/content";
import { createBreadcrumbSchema } from "../lib/schema";

const site = getSiteData();
const breadcrumbs = createBreadcrumbSchema([
  { name: "მთავარი", path: "/" },
  { name: "ნამუშევრები", path: "/gallery/" }
]);
---

<BaseLayout
  title="ნამუშევრები"
  description="იხილეთ Winsome-ის შესრულებული ნამუშევრების მიმართულებები ბინებისთვის, ოფისებისთვის და კომერციული სივრცეებისთვის თბილისში და საქართველოს მასშტაბით."
  pathname="/gallery/"
  schemas={[breadcrumbs]}
>
  <section class="section-padding pb-10">
    <div class="container-shell flex flex-col gap-8">
      <nav aria-label="Breadcrumb" class="text-panel-compact inline-flex flex-wrap items-center text-sm text-ink/60">
        <a href="/" class="hover:text-bronze">მთავარი</a>
        <span class="mx-2">/</span>
        <span>ნამუშევრები</span>
      </nav>
      <SectionHeading
        eyebrow="შესრულებული ნამუშევრები"
        title="გალერეა, რომელიც რეალურ პროექტების არქივს ჰგავს"
        description="ამ ეტაპზე გამოყენებულია დროებითი სურათები, მაგრამ სტრუქტურა მზადაა რეალური ფოტოებისთვის, alt ტექსტებისთვის, ლოკაციებისთვის და შესაბამის პროდუქტზე ბმულებისთვის."
      />
    </div>
  </section>

  <section class="pb-14 sm:pb-16">
    <div class="container-shell">
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {site.gallery.map((item) => (
          <article class="surface-card group overflow-hidden">
            <GalleryCarousel item={item} locale="ka" />
            <div class="space-y-3 p-5 sm:p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink/75">{item.category} • {item.location}</p>
              <h3 class="text-2xl">{item.title}</h3>
              {item.relatedProductSlug && (
                <a class="text-sm font-semibold text-bronze" href={`/products/${item.relatedProductSlug}/`}>
                  შესაბამისი პროდუქტი
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <style>
    @media (prefers-reduced-motion: no-preference) {
      .gallery-img {
        transition: transform 500ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
      }

      .group:hover .gallery-img {
        transform: scale(1.03);
      }
    }
  </style>
</BaseLayout>
